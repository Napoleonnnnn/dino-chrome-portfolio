# ─── Database (Neon PostgreSQL) ───────────────────────
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Admin Authentication ────────────────────────────
# Username for admin CMS login
ADMIN_USERNAME="admin"

# Generate a bcrypt hash for your password:
# Run: node -e "const b=require('bcryptjs');b.hash('YOUR_PASSWORD',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH="$2a$12$..."

# Secret for signing JWT tokens (use a random string, 32+ chars)
JWT_SECRET="your-super-secret-jwt-key-change-me"

# ─── Vercel Blob Storage ─────────────────────────────
# Auto-set by Vercel when you create a Blob store
BLOB_READ_WRITE_TOKEN=""

# ─── GitHub Integration ──────────────────────────────
# Your GitHub username
GITHUB_USERNAME="Napoleonnnnn"

# Optional: Personal Access Token for higher rate limits (60/hr → 5000/hr)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=""
